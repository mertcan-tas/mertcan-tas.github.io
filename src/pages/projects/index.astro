---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectList from '../../components/ProjectList.astro';
import { getProjectsByLang } from '@src/i18n/content';
import { useTranslations } from '@src/i18n/ui';

const t = useTranslations('en');
const projects = (await getProjectsByLang('en')).map((p) => ({
	name: p.data.name,
	description: p.data.description,
	tags: p.data.tags,
	demoLink: p.data.demoLink,
	demoLinkRel: p.data.demoLinkRel,
	repoLink: p.data.repoLink,
	detailLink: p.data.hasDetail === false ? undefined : `/projects/${p.data.translationKey}/`
}));
---

<BaseLayout
	title={t('projects.title')}
	description={t('projects.description')}
>
  <div class='container'>
    <div class="mb-10">
      <h1 class="text-3xl font-bold mb-2">{t('projects.title')}</h1>
      <p class="text-zinc-700 dark:text-zinc-300 text-lg">{t('projects.description')}</p>
    </div>
    <ProjectList projects={projects}/>
  </div>
</BaseLayout>
