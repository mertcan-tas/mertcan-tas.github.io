---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '@src/layouts/BaseLayout.astro';
import { getPoems } from '@src/i18n/content';
import { useTranslations } from '@src/i18n/ui';

export async function getStaticPaths() {
	const poems = await getPoems();
	return poems.map((poem) => ({ params: { slug: poem.id }, props: poem }));
}
type Props = CollectionEntry<'poems'>;
const poem = Astro.props;
const t = useTranslations('tr');
const altLocaleUrl = { en: '/', tr: `/tr/siirler/${poem.id}/` };
const fmtDate = (d: Date) =>
	d.toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title={`${poem.data.title} — ${t('poems.title')}`} description={poem.data.title} altLocaleUrl={altLocaleUrl}>
	<div class='container'>
		<article class='max-w-2xl'>
			<a href='/tr/siirler/' class='text-sm underline opacity-70 hover:opacity-100'>&laquo; {t('poems.title')}</a>
			<h1 class='text-3xl font-bold mt-4 mb-1 leading-tight'>{poem.data.title}</h1>
			<p class='text-sm text-zinc-500 dark:text-zinc-400 mb-8'>{fmtDate(poem.data.date)}</p>
			<p class='whitespace-pre-line font-serif text-lg leading-loose text-zinc-800 dark:text-zinc-200'>
				{poem.data.text.trim()}
			</p>
		</article>
	</div>
</BaseLayout>
