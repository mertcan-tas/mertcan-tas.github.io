---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '@src/layouts/BaseLayout.astro';
import ProjectArticle from '@src/components/ProjectArticle.astro';
import { getProjectsByLang, getProjectByTranslationKey } from '@src/i18n/content';

export async function getStaticPaths() {
	const items = (await getProjectsByLang('tr')).filter((p) => p.data.hasDetail !== false);
	return items.map((project) => ({ params: { slug: project.data.translationKey }, props: project }));
}
type Props = CollectionEntry<'projects'>;
const project = Astro.props;
const { name, description, translationKey } = project.data;
const enProject = await getProjectByTranslationKey(translationKey, 'en');
const altLocaleUrl = {
	en: enProject ? `/projects/${translationKey}/` : '/projects/',
	tr: `/tr/projects/${translationKey}/`
};
---

<BaseLayout title={name} description={description} altLocaleUrl={altLocaleUrl}>
	<ProjectArticle project={project} />
</BaseLayout>
