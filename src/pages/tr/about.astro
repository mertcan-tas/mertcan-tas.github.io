---
import { Image } from 'astro:assets';
import BaseLayout from '@src/layouts/BaseLayout.astro';
import Ava from '@src/assets/img/ava.jpg';
import Prose from '@src/components/Prose.astro';
import { useTranslations } from '@src/i18n/ui';

const t = useTranslations('tr');
---

<BaseLayout title={t('about.title')} description={t('about.p1')}>
	<div class='container'>
		<main class='prose text-lg dark:prose-invert'>
			<article>
				<div class='w-full md:flex md:items-center gap-16 mb-10'>
					<div class='text-pretty leading-9'>
						<h1 class='text-4xl font-bold mb-4'>{t('about.title')}</h1>
						<Prose>
							<div class='text-lg'>
								<p>{t('about.p1')}</p>
								<p>{t('about.p2')}</p>
							</div>
						</Prose>
					</div>
					<Image src={Ava} alt='Mertcan Taş' width={300} class='rounded-3xl rotate-0 mx-4 md:mx-0' />
				</div>
				<div>
					<p>{t('about.p3')}</p>
				</div>
			</article>
		</main>
	</div>
</BaseLayout>
