---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@src/layouts/BaseLayout.astro';
import PostsByYear from '@src/components/PostsByYear.astro';
import { getPostsByLang } from '@src/i18n/content';
import { useTranslations } from '@src/i18n/ui';

type BlogPost = CollectionEntry<'blog'>;
const t = useTranslations('tr');
const title = t('posts.title');
const description = t('posts.description');

const posts = (await getPostsByLang('tr')).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={title} description={description}>
	<div class='container'>
		<div class='mb-10'>
			<h1 class='text-3xl font-bold mb-2'>{title}</h1>
			<p class='text-zinc-700 dark:text-zinc-300 text-lg'>{description}</p>
		</div>
		<PostsByYear posts={posts} />
	</div>
</BaseLayout>
