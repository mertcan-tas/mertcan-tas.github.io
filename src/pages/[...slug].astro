---
import { type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Article from '../components/Article.astro';
import { getPostsByLang, getPostByTranslationKey } from '@src/i18n/content';

export async function getStaticPaths() {
	const posts = await getPostsByLang('en');
	return posts.map((post) => ({ params: { slug: post.id }, props: post }));
}
type Props = CollectionEntry<'blog'>;
const post = Astro.props;
const { title, seoTitle, description, coverImage, translationKey } = post.data;
const trPost = await getPostByTranslationKey(translationKey, 'tr');
const altLocaleUrl = { en: `/${post.id}/`, tr: trPost ? `/tr/${trPost.id}/` : '/tr/' };
---

<BaseLayout title={seoTitle || title} description={description} image={coverImage?.src || undefined} altLocaleUrl={altLocaleUrl}>
	<Article post={post} />
</BaseLayout>
