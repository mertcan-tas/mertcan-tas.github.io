---
interface Props {
	date: Date;
}

const { date } = Astro.props;
const lang = Astro.currentLocale ?? 'en';
const locale = lang === 'tr' ? 'tr-TR' : 'en-US';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale, {
			year: 'numeric',
			month: 'short',
			day: '2-digit',
			timeZone: 'UTC',
		})
	}
</time>
